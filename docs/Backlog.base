views:
  - type: cards
    name: Features
    filters:
      and:
        - file.inFolder("docs/product/features")
        - type == "feature"
    order:
      - file.name
      - tagline
      - personas
      - status
    columnSize:
      file.name: 237
    cardSize: 320
    image: note.image
  - type: table
    name: User Manuals
    filters:
      and:
        - file.inFolder("docs/product/user-manuals")
    order:
      - file.name
      - parent
  - type: table
    name: Plans
    filters:
      and:
        - file.inFolder("docs/superpowers/plans")
    groupBy:
      property: status
      direction: DESC
    order:
      - file.name
      - status
      - parent
      - file.backlinks
    sort:
      - property: file.name
        direction: DESC
      - property: parent
        direction: ASC
    columnSize:
      file.name: 353
      note.status: 128
  - type: table
    name: Specs
    filters:
      and:
        - file.inFolder("docs/superpowers/specs")
    groupBy:
      property: status
      direction: ASC
    order:
      - file.name
      - status
      - parent
    columnSize:
      file.name: 392
      note.status: 175
  - type: table
    name: Issues
    filters:
      and:
        - file.inFolder("docs/issues")
    groupBy:
      property: status
      direction: DESC
    order:
      - type
      - file.name
      - priority
      - status
      - relations
      - tags
    sort:
      - property: priority
        direction: ASC
    columnSize:
      note.type: 102
      file.name: 462
      note.priority: 90
      note.status: 144
      note.relations: 179
      note.tags: 327
  - type: table
    name: Ideas
    filters:
      and:
        - file.inFolder("docs/ideas")
    groupBy:
      property: status
      direction: DESC
    order:
      - file.name
      - status
      - priority
      - relations
      - tags
    columnSize:
      file.name: 460
      note.status: 128
      note.priority: 144
      note.relations: 217
      note.tags: 161
  - type: table
    name: Reviews
    filters:
      and:
        - file.inFolder("docs/reviews")
    order:
      - file.name
      - status
    sort:
      - property: file.name
        direction: DESC
    columnSize:
      file.name: 369
      note.status: 192
  - type: table
    name: ADRs
    filters:
      and:
        - file.inFolder("docs/adr")
    order:
      - file.name
      - status
    columnSize:
      file.name: 353
      note.status: 176
  - type: table
    name: Decisions
    filters:
      and:
        - file.inFolder("docs/decisions")
    order:
      - file.name
      - status
  - type: table
    name: Tech Debt
    filters:
      and:
        - file.inFolder("docs/tech-debt")
    order:
      - file.name
      - status
    columnSize:
      file.name: 349
